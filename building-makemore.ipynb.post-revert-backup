   "outputs": [],
   "source": [
    "# The bigram counts the frequencies of consecutive character pairs \n",
    "b = {}\n",
    "for w in words:\n",
    "    chars = ['.'] + list(w) + ['.']\n",
    "    for char1, char2 in zip(chars, chars[1:]):\n",
    "        bigram = (char1, char2)\n",
    "        b[bigram] = b.get(bigram, 0) + 1\n",
    "        # print(char1, char2)\n",
    "\n",
    "# -----------------------------------------------------------------------------\n",
    "\n",
    "# Sorting the pair:frequency tuples\n",
    "# print(sorted(b.items(), key = lambda kv : -kv[1]))"
   ]
  },
